// // proble - print star "*" in triangle style up side and down side
#include <iostream>
using namespace std;
int main (){
    for (int i = 1; i <= 5; i++) {
        for(int j = 1; j <= i; j++){
            cout << "*";
        }
        cout <<"\n";
    }
    
    for(int i = 5 - 1; i >= 1; i--){
        for(int j = 1; j <= i; j++){
            cout <<"*";
        }
        cout <<"\n";
    }
}
